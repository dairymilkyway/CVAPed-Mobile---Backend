# Node API
NODE_ENV=production
PORT=8080
NODE_APP_ENTRY=path/to/your/real-node-entry.js
JWT_SECRET=replace_with_a_long_random_secret
SECRET_KEY=replace_with_the_same_long_random_secret
CORS_ORIGINS=https://yourapp.com,https://www.yourapp.com

# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/CVACare?retryWrites=true&w=majority
DB_NAME=CVACare

# Internal services
GAIT_ANALYSIS_PORT=5001
GAIT_ANALYSIS_URL=http://127.0.0.1:5001
THERAPY_PORT=5002
THERAPY_URL=http://127.0.0.1:5002
EXERCISE_SERVICE_PORT=5002
FLASK_ENV=production
USE_GLOBAL_PYTHON=true

# OAuth / Firebase
GOOGLE_CLIENT_ID=your_google_client_id
FIREBASE_SERVICE_ACCOUNT_PATH=/run/secrets/firebase-admin.json
# Optional alternatives to file-based Firebase credentials:
# FIREBASE_SERVICE_ACCOUNT_JSON={...json...}
# FIREBASE_SERVICE_ACCOUNT_JSON_BASE64=base64_encoded_json

# Cloudinary
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Azure Speech
AZURE_SPEECH_KEY=your_azure_speech_key
AZURE_SPEECH_REGION=your_azure_speech_region
